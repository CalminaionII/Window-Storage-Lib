using System;
using System.Collections.Generic;
using Vintagestory.API.Client;
using Vintagestory.API.Common;
using Vintagestory.API.Datastructures;
using Vintagestory.API.MathTools;
using Vintagestory.GameContent;

namespace WindowStorageLib
{
    public class BlockWindowStorageLib : Block
    {

        public override bool DoPartialSelection(IWorldAccessor world, BlockPos pos) => true;

        public override bool TryPlaceBlock(IWorldAccessor world, IPlayer byPlayer, ItemStack itemstack, BlockSelection blockSel, ref string failureCode)
        {
            Block closedBlock = world.GetBlock(CodeWithVariant("state", "closed"));
            ItemStack closedStack;
            if (closedBlock != null && closedBlock != this)
            {
                closedStack = new ItemStack(closedBlock);
                if (itemstack?.Attributes != null)
                    closedStack.Attributes.MergeTree(itemstack.Attributes);
            }
            else
            {
                closedStack = itemstack;
            }

            bool placed = base.TryPlaceBlock(world, byPlayer, closedStack, blockSel, ref failureCode);
            if (!placed) return false;

            if (world.BlockAccessor.GetBlockEntity(blockSel.Position) is BEWindowStorageLib be)
            {
                BlockPos blockPos = blockSel.DidOffset ? blockSel.Position.AddCopy(blockSel.Face.Opposite) : blockSel.Position;
                double dx = byPlayer.Entity.Pos.X - (blockPos.X + blockSel.HitPosition.X);
                double dz = byPlayer.Entity.Pos.Z - (blockPos.Z + blockSel.HitPosition.Z);
                float yaw = (float)Math.Atan2(dx, dz);
                float angle = (float)Math.Round(yaw / (GameMath.PI / 2f)) * (GameMath.PI / 2f);

                be.MeshAngleRad = angle;
                be.blockMesh = null;

                if (world.BlockAccessor.GetBlockEntity(blockSel.Position)
                    ?.GetBehavior<BEBehaviorRotatablePlaceable>() is { } rotatableBe)
                {
                    rotatableBe.MeshAngleRad = angle;
                }

                if (world.Side == EnumAppSide.Server)
                    be.MarkDirty(true);
                else
                    be.InitializeWithAngle();
            }

            return true;
        }

        public override Cuboidf[] GetSelectionBoxes(IBlockAccessor blockAccessor, BlockPos pos)
        {
            if (blockAccessor.GetBlockEntity(pos) is BEWindowStorageLib be)
                return RotateBoxes(be.GetSelectionBoxes(), be.MeshAngleRad);
            return base.GetSelectionBoxes(blockAccessor, pos);
        }

        public override Cuboidf[] GetCollisionBoxes(IBlockAccessor blockAccessor, BlockPos pos)
        {
            if (blockAccessor.GetBlockEntity(pos) is BEWindowStorageLib be)
                return RotateBoxes(be.GetCollisionBoxes(), be.MeshAngleRad);
            return base.GetCollisionBoxes(blockAccessor, pos);
        }

        private Cuboidf[] RotateBoxes(Cuboidf[] boxes, float angleRad)
        {
            if (boxes == null) return Array.Empty<Cuboidf>();
            Cuboidf[] rotated = new Cuboidf[boxes.Length];
            for (int i = 0; i < boxes.Length; i++)
                rotated[i] = boxes[i].RotatedCopy(0f, angleRad * GameMath.RAD2DEG, 0f, new Vec3d(0.5, 0.0, 0.5));
            return rotated;
        }

        public override bool OnBlockInteractStart(IWorldAccessor world, IPlayer byPlayer, BlockSelection blockSel)
{
    if (blockSel == null || world == null) return false;
    if (world.BlockAccessor.GetBlockEntity(blockSel.Position) is not BEWindowStorageLib windowBe)
        return false;

    int clickedIndex = blockSel.SelectionBoxIndex;
    ItemSlot handSlot = byPlayer.InventoryManager.ActiveHotbarSlot;

    var ctl = byPlayer.Entity.Controls;
    bool isSneak = ctl.Sneak || ctl.ShiftKey;
    bool isSprint = ctl.Sprint || ctl.CtrlKey;
    bool isWrench = handSlot?.Itemstack?.Collectible?.Code?.Path?.Contains("wrench") == true;

            // 1. FRAME SELECTION BOX
            if (clickedIndex >= windowBe.Inventory.Count)
            {
                int frameBoxIndex = clickedIndex - windowBe.Inventory.Count;

                var frameGroups = windowBe.FrameBoxGroups;
                if (frameGroups == null || frameBoxIndex >= frameGroups.Length)
                    return true;

                var group = frameGroups[frameBoxIndex];
                bool isWindow = group.IsWindow;

                if (handSlot.Empty && !isSneak && windowBe.CanOpen)
                {
                    if (world.Side == EnumAppSide.Server)
                    {
                        windowBe.TogglePane(frameBoxIndex);

                        if (!isWindow)
                        {
                            world.PlaySoundAt(
                                new AssetLocation("game", "sounds/block/door"),
                                blockSel.Position.X + 0.5f,
                                blockSel.Position.Y + 0.5f,
                                blockSel.Position.Z + 0.5f,
                                byPlayer,
                                randomizePitch: true,
                                range: 16f,
                                volume: 1.0f
                            );
                        }
                    }

                    return true;
                }

                return true;
            }



            // 2. CYCLE MODES: Empty Hand + Sneak + Sprint
            if (handSlot.Empty && isSneak && isSprint)
            {
                int groupIndex = windowBe.GetGroupForSlotPublic(clickedIndex);
                var groups = windowBe.GetSlotGroupsPublic();
                if (world.Side == EnumAppSide.Server)
                    TryCycleStaggerMode(windowBe, byPlayer, blockSel, world, groupIndex, groups, false);
                return true;
            }

            // 3. MODE-SPECIFIC ACTIONS
            if (handSlot.Empty && isSprint && !isSneak)
            {
                int groupIndex = windowBe.GetGroupForSlotPublic(clickedIndex);
                StaggerMode mode = (StaggerMode)windowBe.staggerModes[groupIndex];

                if (mode == StaggerMode.Random)
                {
                    var groups = windowBe.GetSlotGroupsPublic();
                    if (world.Side == EnumAppSide.Server)
                        TryCycleStaggerMode(windowBe, byPlayer, blockSel, world, groupIndex, groups, true);
                    return true;
                }

                if (mode == StaggerMode.FineTune)
                {
                    if (world.Side == EnumAppSide.Server)
                        TryCycleFineTuneDepth(windowBe, byPlayer, blockSel, world, 1f);
                    return true;
                }
            }

            // 4. FINE TUNE BACKWARDS: Empty Hand + Sneak only
            if (handSlot.Empty && isSneak && !isSprint)
            {
                int groupIndex = windowBe.GetGroupForSlotPublic(clickedIndex);
                StaggerMode mode = (StaggerMode)windowBe.staggerModes[groupIndex];

                if (mode == StaggerMode.FineTune)
                {
                    if (world.Side == EnumAppSide.Server)
                        TryCycleFineTuneDepth(windowBe, byPlayer, blockSel, world, -1f);
                    return true;
                }
            }
            if (isWrench && !isSneak)
            {
                float direction = isSprint ? -1f : 1f;
                if (world.Side == EnumAppSide.Server)
                    TryRotateItem(windowBe, byPlayer, blockSel, world, direction);
                return true;
            }

            // 5. ITEM INTERACTION: Handle putting/taking items
            return HandleItemInteraction(windowBe, byPlayer, blockSel);
        }

        private bool TryCycleStaggerMode(BEWindowStorageLib be, IPlayer byPlayer, BlockSelection blockSel, IWorldAccessor world, int groupIndex, List<SlotGroupDef> groups, bool forceRandomRoll)
        {
            if (be.staggerModes == null || groupIndex >= be.staggerModes.Length) return false;

            // Determine the range of slots for this group
            int slotStart = 0;
            for (int g = 0; g < groupIndex; g++) slotStart += groups[g].Count;
            int slotEnd = slotStart + groups[groupIndex].Count;

            // 1. If we are cycling the mode (Sneak + Sprint)
            if (!forceRandomRoll)
            {
                int modeCount = Enum.GetNames(typeof(StaggerMode)).Length;
                be.staggerModes[groupIndex] = (be.staggerModes[groupIndex] + 1) % modeCount;

                StaggerMode newMode = (StaggerMode)be.staggerModes[groupIndex];

                // If we just switched to Random or FineTune, reset depths to 0 (Standard position)
                if (newMode == StaggerMode.Random || newMode == StaggerMode.FineTune || newMode == StaggerMode.Straight)
                {
                    for (int i = slotStart; i < Math.Min(slotEnd, be.depths.Length); i++)
                    {
                        be.depths[i] = 0f;
                    }
                }
            }
            // 2. If we are explicitly reshuffling (Sneak + Click while in Random)
            else if ((StaggerMode)be.staggerModes[groupIndex] == StaggerMode.Random)
            {
                var config = WindowStorageLibConfig.Current;
                float voxel = 1f / 32f;
                for (int i = slotStart; i < Math.Min(slotEnd, be.depths.Length); i++)
                {
                    be.depths[i] = (float)Math.Round((world.Rand.NextDouble() * config.StaggerForwardOffset * 2 - config.StaggerForwardOffset) / voxel) * voxel;
                }
            }

            be.MarkDirty(true);
            world.PlaySoundAt(new AssetLocation("game", "sounds/block/cloth"), blockSel.Position, 0, byPlayer);
            return true;
        }

        private bool TryRotateItem(BEWindowStorageLib be, IPlayer byPlayer, BlockSelection blockSel, IWorldAccessor world, float direction)
        {
            int slotIndex = blockSel.SelectionBoxIndex;
            if (slotIndex < 0 || slotIndex >= be.Inventory.Count) return false;
            if (be.Inventory[slotIndex].Empty) return false;

            var config = WindowStorageLibConfig.Current;
            float step = config.RotationStepDegrees;
            be.rotations[slotIndex] = (be.rotations[slotIndex] + step * direction + 360f) % 360f;
            be.MarkDirty(true);

            world.PlaySoundAt(new AssetLocation("game", "sounds/block/cloth"),
                blockSel.Position.X + 0.5f, blockSel.Position.Y + 0.5f, blockSel.Position.Z + 0.5f,
                byPlayer, randomizePitch: true, range: 16f, volume: 0.8f);
            return true;
        }
        private bool TryCycleFineTuneDepth(BEWindowStorageLib be, IPlayer byPlayer, BlockSelection blockSel, IWorldAccessor world, float direction)
        {
            int slotIndex = blockSel.SelectionBoxIndex;
            if (slotIndex < 0 || slotIndex >= be.Inventory.Count) return false;

            float voxel = 1f / 32f;
            float minDepth = -5 * voxel;
            float maxDepth = 5 * voxel;

            float current = be.depths[slotIndex];
            // Direction determines if we add or subtract a voxel
            float next = current + (voxel * direction);

            // Loop logic for both directions
            if (next > maxDepth + 0.001f) next = minDepth;
            if (next < minDepth - 0.001f) next = maxDepth;

            be.depths[slotIndex] = next;
            be.MarkDirty(true);

            world.PlaySoundAt(new AssetLocation("game", "sounds/block/cloth"),
                blockSel.Position.X + 0.5f, blockSel.Position.Y + 0.5f, blockSel.Position.Z + 0.5f,
                byPlayer, randomizePitch: true, range: 16f, volume: 0.6f);
            return true;
        }

        public override byte[] GetLightHsv(IBlockAccessor blockAccessor, BlockPos pos, ItemStack stack = null)
        {
            if (pos != null)
            {
                try
                {
                    if (blockAccessor.GetBlockEntity(pos) is BEWindowStorageLib be && be.Inventory != null)
                    {
                        byte bestV = 0, bestH = 0, bestS = 0;
                        for (int i = 0; i < be.Inventory.Count; i++)
                        {
                            var itemstack = be.Inventory[i]?.Itemstack;
                            if (itemstack?.Collectible?.LightHsv == null) continue;
                            byte v = itemstack.Collectible.LightHsv[2];
                            if (v > bestV)
                            {
                                bestV = v;
                                bestH = itemstack.Collectible.LightHsv[0];
                                bestS = itemstack.Collectible.LightHsv[1];
                            }
                        }
                        if (bestV > 0) return new byte[] { bestH, bestS, bestV };
                    }
                }
                catch { }
            }
            return base.GetLightHsv(blockAccessor, pos, stack);
        }

        private bool HandleItemInteraction(BEWindowStorageLib be, IPlayer byPlayer, BlockSelection blockSel)
        {
            ItemSlot hotbar = byPlayer.InventoryManager.ActiveHotbarSlot;
            if (hotbar.Empty)
                return be.TryTake(byPlayer, blockSel);
            else
                return be.TryPut(hotbar, blockSel);
        }
        public override ItemStack[] GetDrops(IWorldAccessor world, BlockPos pos, IPlayer byPlayer, float dropQuantityMultiplier = 1f)
        {
            Block closedBlock = world.GetBlock(CodeWithVariant("state", "closed")) ?? this;
            ItemStack drop = new ItemStack(closedBlock);
            var arlBehavior = world.BlockAccessor.GetBlockEntity(pos)
                ?.GetBehavior<AttributeRenderingLibrary.BlockEntityBehaviorShapeTexturesFromAttributes>();
            if (arlBehavior?.Variants != null)
                arlBehavior.Variants.ToStack(drop);
            return new ItemStack[] { drop };
        }
    }
}
