        private float Inventory_OnAcquireTransitionSpeed(EnumTransitionType type, ItemStack stack, float baseMul)
        {
            if (type != EnumTransitionType.Perish) return baseMul;
            if (Api == null) return baseMul;

            Room room = container.Room;
            bool effectivelyOpen = IsAnyPaneOpen || (room != null && room.ExitCount > 0);
            return baseMul * (effectivelyOpen ? 2.0f : 0.5f);
        }

        private void DeriveStyleFromBlock()
        {
            string attrStyle = Block?.Attributes?["windowStyle"].AsString(null);
            if (!string.IsNullOrEmpty(attrStyle))
            {
                windowStyle = attrStyle;
                return;
            }

            string blockCode = Block?.Code?.Path;
            if (string.IsNullOrEmpty(blockCode))
            {
                windowStyle = "unknown";
                return;
            }

            int firstDash = blockCode.IndexOf('-');
            if (firstDash < 0)
            {
                windowStyle = blockCode;
                return;
            }

            string afterPrefix = blockCode.Substring(firstDash + 1);
            int secondDash = afterPrefix.IndexOf('-');
            windowStyle = secondDash > 0 ? afterPrefix.Substring(0, secondDash) : afterPrefix;
        }

        private void EnsurePaneStateSize(int index)
        {
            if (index >= paneStates.Length)
                Array.Resize(ref paneStates, index + 1);
        }

        public void TogglePane(int index)
        {
            if (!CanOpen || Api.Side != EnumAppSide.Server) return;

            if (FrameBoxGroups == null || index >= FrameBoxGroups.Length) return;
            var group = FrameBoxGroups[index];

            if (group.StaticFrameBoxes != null &&
                group.OpenFrameBox == null &&
                group.ClosedFrameBox == null) return;

            EnsurePaneStateSize(index);
            paneStates[index] = !paneStates[index];
            BoxCache?.Invalidate();

            MarkDirty(true);

            if (group.IsWindow)
            {
                string targetState = IsAnyWindowPaneOpen ? "open" : "closed";

                if (Block.Variant["state"] != targetState)
                {
                    Block targetBlock = Api.World.GetBlock(Block.CodeWithVariant("state", targetState));
                    if (targetBlock != null && targetBlock != Block)
                    {
                        ITreeAttribute tree = new TreeAttribute();
                        ToTreeAttributes(tree);
                        IBlockAccessor relightAccessor = Api.World.GetBlockAccessor(false, true, false);
                        relightAccessor.ExchangeBlock(targetBlock.Id, Pos);

                        if (relightAccessor.GetBlockEntity(Pos) is BEWindowStorageLib newBe)
                        {
                            newBe.FromTreeAttributes(tree, Api.World);
                            newBe.LightManager.UpdateLightCache();
                            newBe.MarkDirty(true);
                        }
                    }
                }
            }

            if (group.IsWindow && (Block?.Attributes?["linkedOpen"].AsBool(false) ?? false))
            {
                SyncLinkedWindows(index, paneStates[index], null);
            }
        }

        private void SyncLinkedWindows(int index, bool targetState, HashSet<BlockPos> visited = null)
        {
            if (visited == null)
                visited = new HashSet<BlockPos>();

            if (visited.Contains(Pos))
                return;

            visited.Add(Pos);

            EnsurePaneStateSize(index);
            paneStates[index] = targetState;
            UpdateBlockVariant(index);
            MarkDirty(true);

            var upPos = Pos.UpCopy();
            if (Api.World.BlockAccessor.GetBlockEntity(upPos) is BEWindowStorageLib upBe &&
                upBe.Block?.Attributes?["linkedOpen"].AsBool(false) == true)
            {
                upBe.SyncLinkedWindows(index, targetState, visited);
            }

            var downPos = Pos.DownCopy();
            if (Api.World.BlockAccessor.GetBlockEntity(downPos) is BEWindowStorageLib downBe &&
                downBe.Block?.Attributes?["linkedOpen"].AsBool(false) == true)
            {
                downBe.SyncLinkedWindows(index, targetState, visited);
            }
        }

        private void UpdateBlockVariant(int index)
        {
            if (FrameBoxGroups == null || index >= FrameBoxGroups.Length)
                return;

            var group = FrameBoxGroups[index];
            if (!group.IsWindow)
                return;

            string targetState = IsAnyWindowPaneOpen ? "open" : "closed";

            if (Block.Variant["state"] != targetState)
            {
                Block targetBlock = Api.World.GetBlock(Block.CodeWithVariant("state", targetState));
                if (targetBlock != null && targetBlock != Block)
                {
                    ITreeAttribute tree = new TreeAttribute();
                    ToTreeAttributes(tree);
                    IBlockAccessor relightAccessor = Api.World.GetBlockAccessor(false, true, false);
                    relightAccessor.ExchangeBlock(targetBlock.Id, Pos);

                    if (relightAccessor.GetBlockEntity(Pos) is BEWindowStorageLib newBe)
                    {
                        newBe.FromTreeAttributes(tree, Api.World);
                        newBe.LightManager.UpdateLightCache();
                        newBe.MarkDirty(true);
                    }
                }
            }
        }

        public void InitializeWithAngle()
        {
            blockMeshRef?.Dispose();
            blockMeshRef = null;
            blockMesh = null;

            capi?.Event.EnqueueMainThreadTask(() =>
            {
                if (_disposed) return;
                AnimHandler?.InitializeAnimationUtil();
                if (AnimHandler?.animUtil != null)
                    AnimHandler.UpdateAnimations(true);
                MarkMeshesDirty();
            }, "windowstoragelib-initanim");
        }

        private void OnClientTick(float dt)
        {
            if (capi == null) return;
            SoundHandler?.Tick();
            AnimHandler?.UpdateAnimations(false);
        }

        public override void Initialize(ICoreAPI api)
        {
            _disposed = false;

            // Spin up handlers immediately — other code may reference them during init
            LightManager = new WindowLightManager(this);
            LightManager.Reset();
            BoxCache = new WindowBoxCache(this);

            if (Block == null || Block.Id == 0)
            {
                if (api.Side == EnumAppSide.Client && api is ICoreClientAPI clientApi)
                {
                    clientApi.Event.EnqueueMainThreadTask(() =>
                    {
                        api.World.BlockAccessor.SetBlock(0, Pos);
                        api.World.BlockAccessor.RemoveBlockEntity(Pos);
                        api.World.BlockAccessor.MarkBlockDirty(Pos);
                    }, "ghost-cleanup");
                }
                return;
            }

            DeriveStyleFromBlock();
            base.Initialize(api);

            _slotGroups = null;
            int newSlotCount = Block?.Attributes?["slotCount"].AsInt(-1) ?? -1;
            if (newSlotCount < 0)
            {
                JsonObject groupsAttr = Block?.Attributes?["slotGroups"];
                if (groupsAttr != null && groupsAttr.Exists)
                {
                    var arr = groupsAttr.AsArray();
                    newSlotCount = 0;
                    if (arr != null) foreach (var g in arr) newSlotCount += g["count"].AsInt(7);
                }
                else newSlotCount = 7;
            }
            newSlotCount = Math.Clamp(newSlotCount, 0, 64);

            if (inv == null)
            {
                inv = new InventoryGeneric(newSlotCount, null, null);
                inv.OnAcquireTransitionSpeed += Inventory_OnAcquireTransitionSpeed;
            }
            else if (inv.Count != newSlotCount)
            {
                ItemStack[] oldStacks = new ItemStack[inv.Count];
                for (int i = 0; i < inv.Count; i++)
                    oldStacks[i] = inv[i].Itemstack?.Clone();

                inv.OnAcquireTransitionSpeed -= Inventory_OnAcquireTransitionSpeed;
                inv.SlotModified -= OnSlotModified;
                inv = new InventoryGeneric(newSlotCount, null, null);
                inv.OnAcquireTransitionSpeed += Inventory_OnAcquireTransitionSpeed;

                for (int i = 0; i < Math.Min(oldStacks.Length, newSlotCount); i++)
                    if (oldStacks[i] != null)
                        inv[i].Itemstack = oldStacks[i];
            }

            slotCount = newSlotCount;

            if (rotations == null || rotations.Length != newSlotCount)
            {
                float[] newRot = new float[newSlotCount];
                if (rotations != null)
                    Array.Copy(rotations, 0, newRot, 0, Math.Min(rotations.Length, newSlotCount));
                rotations = newRot;
            }

            if (depths == null || depths.Length != newSlotCount)
            {
                float[] newDepth = new float[newSlotCount];
                if (depths != null)
                    Array.Copy(depths, 0, newDepth, 0, Math.Min(depths.Length, newSlotCount));
                depths = newDepth;
            }

            int groupCount = GetSlotGroups().Count;
            if (staggerModes == null || staggerModes.Length != groupCount)
            {
                int[] newModes = new int[groupCount];
                if (staggerModes != null)
                    Array.Copy(staggerModes, 0, newModes, 0, Math.Min(staggerModes.Length, groupCount));
                staggerModes = newModes;
            }

            FrameBoxGroups = Block?.Attributes?["frameBoxGroups"].AsObject<FrameBoxGroup[]>();

            int paneCount = FrameBoxGroups?.Length ?? 0;

            if (paneStates == null || paneStates.Length != paneCount)
            {
                bool[] newStates = new bool[paneCount];
                if (paneStates != null)
                    Array.Copy(paneStates, newStates, Math.Min(paneStates.Length, paneCount));
                paneStates = newStates;
            }

            // Tell BoxCache to pre-parse all JSON box data once
            BoxCache.ParseFromBlock(paneCount, GetSlotGroups());

            inv.LateInitialize(InventoryClassName + "-" + Pos.X + "_" + Pos.Y + "_" + Pos.Z, api);
            inv.SlotModified -= OnSlotModified;
            inv.SlotModified += OnSlotModified;

            container.Init(api, () => Pos, () => MarkDirty(true));
            if (api.Side == EnumAppSide.Server)
            {
                if (serverTickListener != 0)
                {
                    UnregisterGameTickListener(serverTickListener);
                    serverTickListener = 0;
                }
                serverTickListener = RegisterGameTickListener((_) => container.OnTick(0), 10000);
            }

            LightManager.UpdateLightCache();

            if (api.Side == EnumAppSide.Client)
            {
                if (!GuiDialogTransformEditor.extraTransforms.Any(x => x.AttributeName == AttributeTransformCode))
                {
                    GuiDialogTransformEditor.extraTransforms.Add(new TransformConfig()
                    {
                        Title = "Window Storage",
                        AttributeName = AttributeTransformCode
                    });
                }

                AnimHandler = new WindowAnimationHandler(this, capi);
                SoundHandler = new WindowSoundHandler(this, capi);

                AnimHandler.EnqueueInitialSnap();

                if (clientTickListener != 0)
                {
                    UnregisterGameTickListener(clientTickListener);
                    clientTickListener = 0;
                }
                clientTickListener = RegisterGameTickListener(OnClientTick, 500);

                if (eventBusListener != null)
                {
                    api.Event.UnregisterEventBusListener(eventBusListener);
                    eventBusListener = null;
                }
                eventBusListener = OnEventBusEvent;
                api.Event.RegisterEventBusListener(eventBusListener);
            }
        }

        public override void OnBlockPlaced(ItemStack byItemStack = null)
        {
            base.OnBlockPlaced(byItemStack);
            if (Api?.Side == EnumAppSide.Server)
            {
                int paneCount = FrameBoxGroups?.Length ?? 0;
                paneStates = new bool[paneCount];
                staggerModes = new int[GetSlotGroups().Count];
                MarkDirty(true);
            }
        }

        private void OnSlotModified(int slotId)
        {
            if (Api?.Side == EnumAppSide.Client)
            {
                BoxCache?.Invalidate();
                MarkMeshesDirty();
            }

            if (Api?.Side == EnumAppSide.Server)
            {
                byte[] oldLight = LightManager.CachedLightHsv;
                LightManager.UpdateLightCache();
                byte[] newLight = LightManager.CachedLightHsv;

                bool changed = (oldLight == null) != (newLight == null) ||
                    (oldLight != null && newLight != null &&
                    (oldLight[0] != newLight[0] || oldLight[1] != newLight[1] || oldLight[2] != newLight[2]));

                if (changed)
                {
                    if (oldLight != null)
                        Api.World.BlockAccessor.RemoveBlockLight(oldLight, Pos);
                    LightManager.ApplyLight();
                }
            }

            MarkDirty(true);
        }

        public bool IsAnyWindowPaneOpen
        {
            get
            {
                if (paneStates == null || FrameBoxGroups == null) return false;
                for (int i = 0; i < paneStates.Length && i < FrameBoxGroups.Length; i++)
                {
                    if (FrameBoxGroups[i].IsWindow && paneStates[i])
                        return true;
                }
                return false;
            }
        }

