        private Cuboidf[] GetGroupFrameBoxes(int groupIndex)
        {
            string openState = IsAnyPaneOpen ? "open" : "closed";
            JsonObject groupsAttr = Block?.Attributes?["slotGroups"];
            if (groupsAttr != null && groupsAttr.Exists)
            {
                var arr = groupsAttr.AsArray();
                if (arr != null && groupIndex < arr.Length)
                {
                    var g = arr[groupIndex];
                    JsonObject boxes = g[$"{openState}FrameBoxes"];
                    if (boxes == null || !boxes.Exists) boxes = g["staticFrameBoxes"];
                    if (boxes != null && boxes.Exists)
                    {
                        var result = boxes.AsObject<Cuboidf[]>();
                        if (result != null && result.Length > 0) return result;
                    }
                }
            }
            return Array.Empty<Cuboidf>();
        }

        public virtual Cuboidf[] GetSelectionBoxes()
        {
            var groups = GetSlotGroups();
            Cuboidf[] allSlotBoxes = Block?.SelectionBoxes ?? Array.Empty<Cuboidf>();
            var resultList = new List<Cuboidf>();

            // 1. Process Item Slots (Indices 0-6)
            int slotOffset = 0;
            for (int g = 0; g < groups.Count; g++)
            {
                int count = groups[g].Count;

                for (int i = slotOffset; i < slotOffset + count && i < allSlotBoxes.Length; i++)
                {
                    if (!IsGroupStacked(g))
                    {
                        // Keep slot box
                        resultList.Add(allSlotBoxes[i]);
                    }
                    else
                    {
                        // Preserve index alignment with an empty cuboid
                        resultList.Add(new Cuboidf(0, 0, 0, 0, 0, 0));
                    }
                }

                slotOffset += count;
            }

            // 2. Process Window Panes (Indices Inventory.Count+)
            var frameGroups = FrameBoxGroups;
            if (frameGroups != null)
            {
                for (int i = 0; i < frameGroups.Length; i++)
                {
                    // Static box always wins if present
                    if (frameGroups[i].StaticFrameBoxes != null)
                        resultList.AddRange(frameGroups[i].StaticFrameBoxes);

                    bool isOpen = i < paneStates.Length && paneStates[i];
                    var box = isOpen ? frameGroups[i].OpenFrameBox : frameGroups[i].ClosedFrameBox;
                    if (box != null) resultList.Add(box);
                }
            }

            return resultList.ToArray();
        }




        public Cuboidf[] GetCollisionBoxes()
        {
            List<Cuboidf> result = new List<Cuboidf>();

            // 2. Try per‑pane collision groups
            var collisionGroups = cachedCollisionGroups;
            if (collisionGroups != null)
            {
                for (int i = 0; i < collisionGroups.Length; i++)
                {
                    var group = collisionGroups[i];

                    // Static boxes are always added regardless of pane state
                    if (group.StaticCollisionBoxes != null)
                        result.AddRange(group.StaticCollisionBoxes);

                    bool isOpen = i < paneStates.Length && paneStates[i];
                    var box = isOpen ? group.OpenCollisionBox : group.ClosedCollisionBox;
                    if (box != null) result.Add(box);
                }

                return result.ToArray();
            }

            // 1. Add slot collision boxes (from the block JSON) only if no collisionBoxGroups
            var slotBoxes = Block?.CollisionBoxes;
            if (slotBoxes != null)
                result.AddRange(slotBoxes);

            // 3. Fallback to your existing flat collision arrays
            if (IsAnyWindowPaneOpen)
            {
                var openBoxes = Block?.Attributes?["openCollisionBoxes"]?.AsObject<Cuboidf[]>();
                if (openBoxes != null)
                    result.AddRange(openBoxes);
            }
            else
            {
                var closedBoxes = Block?.Attributes?["closedCollisionBoxes"]?.AsObject<Cuboidf[]>();
                if (closedBoxes != null)
                    result.AddRange(closedBoxes);
            }

            return result.ToArray();
        }

        private int GetGroupForSlot(int slotIndex)
        {
            var groups = GetSlotGroups();
            int offset = 0;
            for (int g = 0; g < groups.Count; g++)
            {
                if (slotIndex < offset + groups[g].Count) return g;
                offset += groups[g].Count;
            }
            return 0;
        }

        public bool TryPut(ItemSlot slot, BlockSelection blockSel)
        {
            if (blockSel == null) return false;
            int index = blockSel.SelectionBoxIndex;
            if (index < 0 || index >= slotCount) return false;
            if (IsGroupStacked(GetGroupForSlot(index))) return false;
            ItemSlot targetSlot = inv[index];
            if (!targetSlot.Empty) return false;
            int moved = slot.TryPutInto(Api.World, targetSlot);
            if (moved > 0)
            {
                MarkDirty(true);
                Api.World.PlaySoundAt(new AssetLocation("game", "sounds/player/build"), Pos.X + 0.5, Pos.Y + 0.5, Pos.Z + 0.5, null, randomizePitch: true, range: 16);
                return true;
            }
            return false;
        }

        public bool TryTake(IPlayer byPlayer, BlockSelection blockSel)
        {
            if (blockSel == null) return false;
            int index = blockSel.SelectionBoxIndex;
            if (index < 0 || index >= slotCount) return false;
            if (IsGroupStacked(GetGroupForSlot(index))) return false;
            ItemSlot sourceSlot = inv[index];
            if (sourceSlot.Empty) return false;
            ItemStack stack = sourceSlot.TakeOut(1);
            if (byPlayer.InventoryManager.TryGiveItemstack(stack))
            {
                MarkDirty(true);
                Api.World.PlaySoundAt(new AssetLocation("game", "sounds/player/build"), Pos.X + 0.5, Pos.Y + 0.5, Pos.Z + 0.5, null, randomizePitch: true, range: 16);
                return true;
            }
            sourceSlot.Itemstack = stack;
            return false;
        }
