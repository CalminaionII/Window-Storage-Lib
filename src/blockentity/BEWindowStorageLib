        private int[] GetStackingHideGroups()
        {
            var attr = Block?.Attributes?["stackingHideGroups"];
            if (attr == null || !attr.Exists) return null;
            return attr.AsArray<int>(null);
        }

        public bool IsGroupStacked(int groupIndex)
        {
            if (!IsStacked) return false;
            int[] hideGroups = GetStackingHideGroups();
            if (hideGroups == null) return true;
            return System.Array.IndexOf(hideGroups, groupIndex) >= 0;
        }

