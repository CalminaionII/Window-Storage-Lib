        internal void InitializeAnimationUtil()
        {
            if (capi == null || Block == null) return;
            animUtil?.Dispose();
            animUtil = null;

            try
            {
                string shapePath = Block?.Attributes?["animationShapePath"].AsString();
                if (string.IsNullOrEmpty(shapePath)) return;

                Shape animShape = capi.Assets.TryGet(shapePath)?.ToObject<Shape>();
                if (animShape == null)
                {
                    Api.Logger.Warning($"[WindowStorageLib] Failed to load animation shape: {shapePath}");
                    return;
                }

                ITexPositionSource texSource;
                var arlBlockBehavior = Block?.GetBehavior<BlockBehaviorShapeTexturesFromAttributes>();
                var arlBeBehavior = this.GetBehavior<BlockEntityBehaviorShapeTexturesFromAttributes>();

                if (arlBlockBehavior != null && arlBeBehavior != null)
                {
                    // This is what worked in your old code
                    var stexSource = new UniversalShapeTextureSource(capi, capi.BlockTextureAtlas, animShape, shapePath);
                    foreach (var (code, texture) in Block.Textures)
                        stexSource.textures[code] = texture;

                    ShapeOverlayHelper.BakeVariantTextures(capi, stexSource, arlBeBehavior.Variants, arlBlockBehavior.texturesByType);
                    texSource = stexSource;
                }
                else
                {
                    texSource = capi.Tesselator.GetTextureSource(Block);
                }

                float rot = MeshAngleRad * GameMath.RAD2DEG;
                animUtil = new BlockEntityAnimationUtil(capi, this);
                animUtil.InitializeAnimator($"window-{windowStyle}-{Pos.X}-{Pos.Y}-{Pos.Z}", animShape, texSource, new Vec3f(0, rot, 0));
            }
            catch (Exception e)
            {
                Api.Logger.Error($"[WindowStorageLib] Error initializing animation: {e.Message}");
                animUtil = null;
            }
        }

        private void UpdateAnimations(bool instant = false)
        {
            if (animUtil == null) return;

            var frameGroups = FrameBoxGroups;
            if (frameGroups == null) return;

            // Pull the speed from your config
            float configSpeed = WindowStorageLibConfig.Current.AnimationSpeedValue;

            for (int i = 0; i < frameGroups.Length; i++)
            {
                if (i >= paneStates.Length) continue;

                var group = frameGroups[i];

                // Skip static groups that have no animations
                if (string.IsNullOrEmpty(group.AnimOpen) || string.IsNullOrEmpty(group.AnimClose))
                    continue;

                string targetAnim = paneStates[i] ? group.AnimOpen : group.AnimClose;
                string oppositeAnim = paneStates[i] ? group.AnimClose : group.AnimOpen;

                if (animUtil.activeAnimationsByAnimCode.ContainsKey(oppositeAnim))
                {
                    animUtil.StopAnimation(oppositeAnim);
                }

                if (!animUtil.activeAnimationsByAnimCode.ContainsKey(targetAnim))
                {
                    var meta = new AnimationMetaData()
                    {
                        Animation = targetAnim,
                        Code = targetAnim,
                        AnimationSpeed = configSpeed, // Applied here
                        EaseInSpeed = 10.0f,
                        EaseOutSpeed = 5f,
                        Weight = 1.0f,
                        BlendMode = EnumAnimationBlendMode.Add
                    };

                    animUtil.StartAnimation(meta);
                }
            }
        }

        private byte[] _lastKnownLightHsv = null;
        public byte[] CachedLightHsv => _lastKnownLightHsv;
        private int _lightUpdateGeneration = 0;
        private bool _blockBroken = false;

        internal void UpdateLightCache()
        {
            if (inv == null) return;
            byte bestV = 0, bestH = 0, bestS = 0;
            for (int i = 0; i < inv.Count; i++)
            {
                var itemstack = inv[i]?.Itemstack;
                if (itemstack?.Collectible?.LightHsv == null) continue;
                byte v = itemstack.Collectible.LightHsv[2];
                if (v > bestV)
                {
                    bestV = v;
                    bestH = itemstack.Collectible.LightHsv[0];
                    bestS = itemstack.Collectible.LightHsv[1];
                }
            }
            _lastKnownLightHsv = bestV > 0 ? new byte[] { bestH, bestS, bestV } : null;
        }

        internal void ApplyLight()
        {
            if (Api?.Side != EnumAppSide.Server || Pos == null) return;
            if (_lastKnownLightHsv == null) return;
            int generation = ++_lightUpdateGeneration;

            ItemStack[] stacks = new ItemStack[inv.Count];
            for (int i = 0; i < inv.Count; i++)
                stacks[i] = inv[i]?.Itemstack?.Clone();
            float angle = MeshAngleRad;
            bool[] snapPaneStates = (bool[])paneStates.Clone();
            int[] snapStaggerModes = (int[])staggerModes?.Clone() ?? Array.Empty<int>();
            float[] snapRotations = (float[])rotations.Clone();
            float[] snapDepths = (float[])depths.Clone();

            Api.Event.EnqueueMainThreadTask(() =>
            {
                if (_lightUpdateGeneration != generation || Api == null || Pos == null || _blockBroken) return;
                if (Api.World.BlockAccessor.GetBlock(Pos).Id != Block.Id) return;
                Api.World.BlockAccessor.ExchangeBlock(Block.Id, Pos);
                if (Api.World.BlockAccessor.GetBlockEntity(Pos) is BEWindowStorageLib newBe)
                {
                    for (int i = 0; i < Math.Min(stacks.Length, newBe.inv.Count); i++)
                        newBe.inv[i].Itemstack = stacks[i];
                    newBe.MeshAngleRad = angle;
                    newBe.paneStates = snapPaneStates;
                    newBe.staggerModes = snapStaggerModes;
                    newBe.rotations = snapRotations;
                    newBe.depths = snapDepths;
                    newBe.UpdateLightCache();
                    newBe.MarkDirty(true);
                }
            }, "windowlight");
        }

        private void OnSlotModified(int slotId)
        {
            if (Api?.Side == EnumAppSide.Client)
                MarkMeshesDirty();

            if (Api?.Side == EnumAppSide.Server)
            {
                byte[] oldLight = _lastKnownLightHsv;
                UpdateLightCache();
                byte[] newLight = _lastKnownLightHsv;

                bool changed = (oldLight == null) != (newLight == null) ||
                    (oldLight != null && newLight != null &&
                    (oldLight[0] != newLight[0] || oldLight[1] != newLight[1] || oldLight[2] != newLight[2]));

                if (changed)
                {
                    if (oldLight != null)
                        Api.World.BlockAccessor.RemoveBlockLight(oldLight, Pos);
                    ApplyLight();
                }
            }

            MarkDirty(true);
        }

        public bool IsAnyWindowPaneOpen
        {
            get
            {
                if (paneStates == null || FrameBoxGroups == null) return false;
                for (int i = 0; i < paneStates.Length && i < FrameBoxGroups.Length; i++)
                {
                    if (FrameBoxGroups[i].IsWindow && paneStates[i])
                        return true;
                }
                return false;
            }
        }

