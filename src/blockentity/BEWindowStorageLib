        private bool PlayerNearThisWindow(float range)
        {
            if (capi == null) return false;
            Vec3d playerPos = capi.World.Player.Entity.Pos.XYZ;
            double dx = playerPos.X - (Pos.X + 0.5);
            double dy = playerPos.Y - (Pos.Y + 0.5);
            double dz = playerPos.Z - (Pos.Z + 0.5);
            return (dx * dx + dy * dy + dz * dz) <= (range * range);
        }

        private bool IsRainedOn(BlockPos pos)
        {
            if (capi == null) return false;
            ClimateCondition cond = capi.World.BlockAccessor.GetClimateAt(pos, EnumGetClimateMode.NowValues);
            if (cond == null || cond.Rainfall <= 0.1f || cond.Temperature <= 3f) return false;
            return capi.World.BlockAccessor.GetRainMapHeightAt(pos) <= pos.Y ||
                   capi.World.BlockAccessor.GetDistanceToRainFall(pos, 3) <= 2;
        }

        private float ComputeTargetRainVolume(BlockPos ownerPos)
        {
            ClimateCondition cond = capi.World.BlockAccessor.GetClimateAt(ownerPos, EnumGetClimateMode.NowValues);
            float intensity = Math.Clamp(cond?.Rainfall ?? 0f, 0f, 1.5f);
            return Math.Clamp(WindowStorageLibConfig.Current.RainSoundVolumeValue * intensity, 0f, 2f);
        }

        private void FadeSharedSoundsToCurrentTarget()
        {
            if (SharedSounds.TryGetValue("rain", out var rainEntry)
                && rainEntry.sound != null && !rainEntry.sound.IsDisposed && rainEntry.sound.IsPlaying)
            {
                float target = ComputeTargetRainVolume(rainEntry.owner);
                rainEntry.sound.FadeTo(target, FadeSpeed, (_) => { });
            }
        }

        private void OnClientTick(float dt)
        {
            if (capi == null) return;

            TickSharedRainSound();
            UpdateAnimations(false);        // Keep panes updated
        }

        private void TickSharedRainSound()
        {
            bool shouldPlay = WindowStorageLibConfig.Current.EnableRainSound
                && !(Block?.Attributes?["disableRainSound"].AsBool(false) ?? false)
                && IsRainedOn(Pos)
                && PlayerNearThisWindow((float)WindowStorageLibConfig.Current.RainSoundRange);

            if (SharedSounds.TryGetValue("rain", out var existing))
            {
                bool soundAlive = existing.sound != null && !existing.sound.IsDisposed && existing.sound.IsPlaying;

                if (soundAlive)
                {
                    existing.sound.SetPosition(capi.World.Player.Entity.Pos.XYZFloat);

                    float target = ComputeTargetRainVolume(existing.owner);
                    existing.sound.SetVolume(GameMath.Lerp(existing.sound.Params.Volume, target, SmoothSpeed));

                    if (!shouldPlay && existing.owner == Pos)
                    {
                        existing.sound.FadeOutAndStop(FadeSpeed);
                        SharedSounds.Remove("rain");
                    }
                    return;
                }

                TryDisposeSound(existing.sound);
                SharedSounds.Remove("rain");
            }

            if (!shouldPlay) return;

            ILoadedSound newSound = capi.World.LoadSound(new SoundParams()
            {
                Location = new AssetLocation("game", "sounds/environment/rainwindow"),
                ShouldLoop = true,
                Position = capi.World.Player.Entity.Pos.XYZFloat,
                DisposeOnFinish = false,
                Volume = ComputeTargetRainVolume(Pos),
                Pitch = 1.0f
            });

            if (newSound != null)
            {
                newSound.Start();
                SharedSounds["rain"] = (Pos, newSound);
            }
        }

        private void TryDisposeSound(ILoadedSound sound)
        {
            if (sound == null) return;
            try
            {
                if (!sound.IsDisposed)
                {
                    sound.Stop();
                    sound.Dispose();
                }
            }
            catch { }
        }

        public override void Initialize(ICoreAPI api)
        {
            _disposed = false;  // ← add this line
            if (Block == null || Block.Id == 0)
            {
                if (api.Side == EnumAppSide.Client && api is ICoreClientAPI clientApi)
                {
                    clientApi.Event.EnqueueMainThreadTask(() =>
                    {
                        api.World.BlockAccessor.SetBlock(0, Pos);
                        api.World.BlockAccessor.RemoveBlockEntity(Pos);
                        api.World.BlockAccessor.MarkBlockDirty(Pos);
                    }, "ghost-cleanup");
                }
                return;
            }

            DeriveStyleFromBlock();
            base.Initialize(api);

            _slotGroups = null;
            int newSlotCount = Block?.Attributes?["slotCount"].AsInt(-1) ?? -1;
            if (newSlotCount < 0)
            {
                JsonObject groupsAttr = Block?.Attributes?["slotGroups"];
                if (groupsAttr != null && groupsAttr.Exists)
                {
                    var arr = groupsAttr.AsArray();
                    newSlotCount = 0;
                    if (arr != null) foreach (var g in arr) newSlotCount += g["count"].AsInt(7);
                }
                else newSlotCount = 7;
            }
            newSlotCount = Math.Clamp(newSlotCount, 0, 64);

            if (inv == null)
            {
                inv = new InventoryGeneric(newSlotCount, null, null);
                inv.OnAcquireTransitionSpeed += Inventory_OnAcquireTransitionSpeed;
            }
            else if (inv.Count != newSlotCount)
            {
                ItemStack[] oldStacks = new ItemStack[inv.Count];
                for (int i = 0; i < inv.Count; i++)
                    oldStacks[i] = inv[i].Itemstack?.Clone();

                inv.OnAcquireTransitionSpeed -= Inventory_OnAcquireTransitionSpeed;
                inv.SlotModified -= OnSlotModified;
                inv = new InventoryGeneric(newSlotCount, null, null);
                inv.OnAcquireTransitionSpeed += Inventory_OnAcquireTransitionSpeed;

                for (int i = 0; i < Math.Min(oldStacks.Length, newSlotCount); i++)
                    if (oldStacks[i] != null)
                        inv[i].Itemstack = oldStacks[i];
            }

            slotCount = newSlotCount;

            if (rotations == null || rotations.Length != newSlotCount)
            {
                float[] newRot = new float[newSlotCount];
                if (rotations != null)
                    Array.Copy(rotations, 0, newRot, 0, Math.Min(rotations.Length, newSlotCount));
                rotations = newRot;
            }

            if (depths == null || depths.Length != newSlotCount)
            {
                float[] newDepth = new float[newSlotCount];
                if (depths != null)
                    Array.Copy(depths, 0, newDepth, 0, Math.Min(depths.Length, newSlotCount));
                depths = newDepth;
            }

            int groupCount = GetSlotGroups().Count;
            if (staggerModes == null || staggerModes.Length != groupCount)
            {
                int[] newModes = new int[groupCount];
                if (staggerModes != null)
                    Array.Copy(staggerModes, 0, newModes, 0, Math.Min(staggerModes.Length, groupCount));
                staggerModes = newModes;
            }

            // 2. NEW: Handle Separated Window Pane States
            // This looks at "frameBoxGroups" in your JSON to decide how many panes we have
            FrameBoxGroups = Block?.Attributes?["frameBoxGroups"].AsObject<FrameBoxGroup[]>();
            cachedCollisionGroups = Block?.Attributes?["collisionBoxGroups"]?.AsObject<CollisionBoxGroup[]>();

            int paneCount = FrameBoxGroups?.Length ?? 0;

            if (paneStates == null || paneStates.Length != paneCount)
            {
                bool[] newStates = new bool[paneCount];
                if (paneStates != null)
                    Array.Copy(paneStates, newStates, Math.Min(paneStates.Length, paneCount));
                paneStates = newStates;
            }
            var slotGroups = GetSlotGroups();

            // 1. Count active slots (ignoring stacked groups)
            cachedSlotStartIndex = 0;
            for (int g = 0; g < slotGroups.Count; g++)
            {
                if (!IsGroupStacked(g))
                    cachedSlotStartIndex += slotGroups[g].Count;
            }

            // 2. Cache frame counts and start indices
            cachedFrameCounts = new int[paneCount];
            cachedFrameStartIndex = new int[paneCount];

            int running = cachedSlotStartIndex;
            for (int i = 0; i < paneCount; i++)
            {
                // Casement windows always have 1 frame box per pane
                cachedFrameCounts[i] = 1;

                cachedFrameStartIndex[i] = running;
                running += cachedFrameCounts[i];
            }


            inv.LateInitialize(InventoryClassName + "-" + Pos.X + "_" + Pos.Y + "_" + Pos.Z, api);
            inv.SlotModified -= OnSlotModified;
            inv.SlotModified += OnSlotModified;

            container.Init(api, () => Pos, () => MarkDirty(true));
            if (api.Side == EnumAppSide.Server)
            {
                if (serverTickListener != 0)
                {
                    UnregisterGameTickListener(serverTickListener);
                    serverTickListener = 0;
                }
                serverTickListener = RegisterGameTickListener((_) => container.OnTick(0), 10000);
            }

            UpdateLightCache();

            if (api.Side == EnumAppSide.Client)
            {
                if (!GuiDialogTransformEditor.extraTransforms.Any(x => x.AttributeName == AttributeTransformCode))
                {
                    GuiDialogTransformEditor.extraTransforms.Add(new TransformConfig()
                    {
                        Title = "Window Storage",
                        AttributeName = AttributeTransformCode
                    });
                }

                capi?.Event.EnqueueMainThreadTask(() =>
                {
                    if (_disposed) return;
                    InitializeAnimationUtil();
                    if (animUtil != null)
                    {
                        string globalState = IsAnyWindowPaneOpen ? "open" : "closed";
                        animUtil.StartAnimation(new AnimationMetaData()
                        {
                            Animation = globalState,
                            Code = globalState,
                            AnimationSpeed = 1000f
                        });
                    }
                    MarkMeshesDirty();
                }, "windowstoragelib-initanim");

                if (clientTickListener != 0)
                {
                    UnregisterGameTickListener(clientTickListener);
                    clientTickListener = 0;
                }
                clientTickListener = RegisterGameTickListener(OnClientTick, 500);

                if (eventBusListener != null)
                {
                    api.Event.UnregisterEventBusListener(eventBusListener);
                    eventBusListener = null;
                }
                eventBusListener = OnEventBusEvent;
                api.Event.RegisterEventBusListener(eventBusListener);
            }
        }

