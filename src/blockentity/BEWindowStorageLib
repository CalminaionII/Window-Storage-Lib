        public override void FromTreeAttributes(ITreeAttribute tree, IWorldAccessor world)
        {
            // 1. Handle Inventory and Slot Logic
            int newSlotCount = Block?.Attributes?["slotCount"].AsInt(-1) ?? -1;
            if (newSlotCount < 0)
            {
                JsonObject groupsAttr = Block?.Attributes?["slotGroups"];
                if (groupsAttr != null && groupsAttr.Exists)
                {
                    var arr = groupsAttr.AsArray();
                    newSlotCount = 0;
                    if (arr != null) foreach (var g in arr) newSlotCount += g["count"].AsInt(7);
                }
                else newSlotCount = 7;
            }
            newSlotCount = Math.Clamp(newSlotCount, 1, 64);

            if (inv != null && inv.Count != newSlotCount)
            {
                ItemStack[] oldStacks = new ItemStack[inv.Count];
                for (int i = 0; i < inv.Count; i++)
                    oldStacks[i] = inv[i].Itemstack?.Clone();

                inv.OnAcquireTransitionSpeed -= Inventory_OnAcquireTransitionSpeed;
                inv.SlotModified -= OnSlotModified;
                inv = new InventoryGeneric(newSlotCount, null, null);
                inv.OnAcquireTransitionSpeed += Inventory_OnAcquireTransitionSpeed;

                for (int i = 0; i < Math.Min(oldStacks.Length, newSlotCount); i++)
                    if (oldStacks[i] != null)
                        inv[i].Itemstack = oldStacks[i];
            }

            slotCount = newSlotCount;
            base.FromTreeAttributes(tree, world);

            // 2. Handle Rotations and Depths
            rotations = (tree["rotations"] as FloatArrayAttribute)?.value ?? new float[newSlotCount];
            depths = (tree["depths"] as FloatArrayAttribute)?.value ?? new float[newSlotCount];

            if (rotations.Length != slotCount)
            {
                float[] newRot = new float[slotCount];
                Array.Copy(rotations, 0, newRot, 0, Math.Min(rotations.Length, slotCount));
                rotations = newRot;
            }

            if (depths.Length != slotCount)
            {
                float[] newDepth = new float[slotCount];
                Array.Copy(depths, 0, newDepth, 0, Math.Min(depths.Length, slotCount));
                depths = newDepth;
            }

            _slotGroups = null;
            float previousAngle = MeshAngleRad;

            // 3. Handle Pane States
            bool[] oldPaneStates = paneStates != null ? (bool[])paneStates.Clone() : null;

            string states = tree.GetString("paneStates", "");
            if (!string.IsNullOrEmpty(states))
            {
                paneStates = new bool[states.Length];
                for (int i = 0; i < states.Length; i++)
                    paneStates[i] = states[i] == '1';
            }
            else
            {
                bool legacyOpen = tree.GetBool("isOpen", false);
                paneStates = new bool[] { legacyOpen };
            }

            BoxCache?.Invalidate();

            // 4. Handle Stagger Modes
            int groupCount = GetSlotGroups().Count;
            int[] loadedModes = (tree["staggerModes"] as IntArrayAttribute)?.value;
            if (loadedModes != null && loadedModes.Length == groupCount)
                staggerModes = loadedModes;
            else
            {
                int legacy = tree.GetInt("staggerMode", 0);
                staggerModes = new int[groupCount];
                for (int i = 0; i < groupCount; i++) staggerModes[i] = legacy;
            }

            MeshAngleRad = tree.GetFloat("meshAngleRad", 0f);
            blockMesh = null;

            LightManager?.UpdateLightCache();
            RedrawAfterReceivingTreeAttributes(world);

            // 5. Client-Side Visuals and Animations
            if (Api?.Side == EnumAppSide.Client)
                AnimHandler?.EnqueueStateSync(previousAngle, oldPaneStates);
        }

        public override void ToTreeAttributes(ITreeAttribute tree)
        {
            base.ToTreeAttributes(tree);
            tree["rotations"] = new FloatArrayAttribute(rotations);
            tree["depths"] = new FloatArrayAttribute(depths);
            tree["staggerModes"] = new IntArrayAttribute(staggerModes ?? Array.Empty<int>());

            var stateChars = new char[paneStates.Length];
            for (int i = 0; i < paneStates.Length; i++)
                stateChars[i] = paneStates[i] ? '1' : '0';
            tree.SetString("paneStates", new string(stateChars));

            tree.SetFloat("meshAngleRad", MeshAngleRad);
        }

        private void CleanupClient()
        {
            _disposed = true;
            blockMeshRef?.Dispose();
            blockMeshRef = null;
            blockMesh = null;

            AnimHandler?.Dispose();
            AnimHandler = null;

            SoundHandler?.Dispose();
            SoundHandler = null;

            if (clientTickListener != 0)
            {
                UnregisterGameTickListener(clientTickListener);
                clientTickListener = 0;
            }

            if (eventBusListener != null && Api != null)
            {
                Api.Event.UnregisterEventBusListener(eventBusListener);
                eventBusListener = null;
            }
        }

        public override void OnBlockRemoved()
        {
            LightManager?.OnBlockRemoved();

            if (inv != null)
            {
                inv.OnAcquireTransitionSpeed -= Inventory_OnAcquireTransitionSpeed;
                inv.SlotModified -= OnSlotModified;
                inv.Clear();
            }
            if (serverTickListener != 0)
            {
                UnregisterGameTickListener(serverTickListener);
                serverTickListener = 0;
            }

            CleanupClient();
            base.OnBlockRemoved();
        }

        public override void OnBlockUnloaded()
        {
            if (inv != null)
            {
                inv.OnAcquireTransitionSpeed -= Inventory_OnAcquireTransitionSpeed;
                inv.SlotModified -= OnSlotModified;
            }
            if (serverTickListener != 0)
            {
                UnregisterGameTickListener(serverTickListener);
                serverTickListener = 0;
            }

            CleanupClient();
            base.OnBlockUnloaded();
        }

        public override void GetBlockInfo(IPlayer forPlayer, StringBuilder dsc)
        {
            if (Block?.Attributes?["pairedWith"].AsString(null) == "below")
            {
                BlockPos belowPos = Pos.DownCopy();
                while (Api.World.BlockAccessor.GetBlockEntity(belowPos) is BEWindowStorageLib belowBe &&
                       belowBe.Block?.Attributes?["pairedWith"].AsString(null) == "below")
                {
                    belowPos = belowPos.DownCopy();
                }

                if (Api.World.BlockAccessor.GetBlockEntity(belowPos) is BEWindowStorageLib bottomBe)
                    bottomBe.GetBlockInfo(forPlayer, dsc);
                return;
            }

            string styleDisplay = windowStyle.Length > 0 ? char.ToUpper(windowStyle[0]) + windowStyle.Substring(1) : windowStyle;
            if (CanOpen)
            {
                string state = IsAnyWindowPaneOpen ? Lang.Get("Open") : Lang.Get("Closed");
                dsc.AppendLine(state);
            }
            else
            {
                dsc.AppendLine(styleDisplay);
            }

            if (IsFullyStacked) return;

            var groups = GetSlotGroups();
            var activeGroups = new List<int>();
            for (int g = 0; g < groups.Count; g++)
                if (!IsGroupStacked(g)) activeGroups.Add(g);

            if (activeGroups.Count == 1)
            {
                string modeName = GetGroupStaggerMode(activeGroups[0]) == StaggerMode.FineTune ? "Fine Tune" : GetGroupStaggerMode(activeGroups[0]).ToString();
                dsc.AppendLine(Lang.Get("Display: {0}", modeName));
            }
            else
            {
                foreach (int g in activeGroups)
                {
                    string modeName = GetGroupStaggerMode(g) == StaggerMode.FineTune ? "Fine Tune" : GetGroupStaggerMode(g).ToString();
                    dsc.AppendLine(Lang.Get("Display {0}: {1}", g + 1, modeName));
                }
            }

            container.ReloadRoom();
            float perishRate = container.GetPerishRate();

            if (inv is InventoryGeneric inventoryGeneric)
            {
                float num;
                if (inventoryGeneric.TransitionableSpeedMulByType != null && inventoryGeneric.TransitionableSpeedMulByType.TryGetValue((EnumTransitionType)0, out num))
                    perishRate *= num;

                if (inventoryGeneric.PerishableFactorByFoodCategory != null)
                {
                    dsc.AppendLine(Lang.Get("Stored food perish speed:"));
                    foreach (KeyValuePair<EnumFoodCategory, float> kvp in inventoryGeneric.PerishableFactorByFoodCategory)
                    {
                        string catName = Lang.Get("foodcategory-" + kvp.Key.ToString().ToLowerInvariant());
                        dsc.AppendLine(Lang.Get("- {0}: {1}x", catName, Math.Round(perishRate * kvp.Value, 2)));
                    }
                    if (inventoryGeneric.PerishableFactorByFoodCategory.Count < Enum.GetValues(typeof(EnumFoodCategory)).Length)
                        dsc.AppendLine(Lang.Get("- {0}: {1}x", Lang.Get("food_perish_speed_other"), Math.Round(perishRate, 2)));
                }
                else
                {
                    dsc.AppendLine(Lang.Get("Stored food perish speed: {0}x", Math.Round(perishRate, 2)));
                }
            }
            else
            {
                dsc.AppendLine(Lang.Get("Stored food perish speed: {0}x", Math.Round(perishRate, 2)));
            }

            float ripenRate = GameMath.Clamp((float)((1.0 - perishRate - 0.5) * 3.0), 0f, 1f);
            if (ripenRate > 0f)
                dsc.AppendLine(Lang.Get("Suitable spot for food ripening."));

            if (forPlayer?.CurrentBlockSelection != null && forPlayer.CurrentBlockSelection.Position == Pos)
            {
                int slotIndex = forPlayer.CurrentBlockSelection.SelectionBoxIndex;
                if (slotIndex >= 0 && slotIndex < inv.Count)
                {
                    ItemSlot slot = inv[slotIndex];
                    if (slot.Empty)
                        dsc.AppendLine(Lang.Get("Empty"));
                    else
                        dsc.Append(PerishableInfoCompact(Api, slot, ripenRate));
                }
            }
        }

        public static string PerishableInfoCompact(ICoreAPI api, ItemSlot contentSlot, float ripenRate, bool withStackName = true)
        {
            if (contentSlot.Empty) return "";
            StringBuilder sb = new StringBuilder();
            if (withStackName) sb.Append(contentSlot.Itemstack.GetName());

            TransitionState[] transitionStates = contentSlot.Itemstack.Collectible.UpdateAndGetTransitionStates(api.World, contentSlot);
            if (transitionStates == null) return sb.ToString();

            bool hasPerish = false;
            for (int i = 0; i < transitionStates.Length; i++)
            {
                TransitionState state = transitionStates[i];
                TransitionableProperties props = state.Props;
                float rateMul = contentSlot.Itemstack.Collectible.GetTransitionRateMul(api.World, contentSlot, props.Type);
                if (rateMul <= 0f) continue;

                float transitionLevel = state.TransitionLevel;
                float freshHoursLeft = state.FreshHoursLeft / rateMul;

                if (props.Type == EnumTransitionType.Ripen && !hasPerish)
                {
                    if (transitionLevel > 0f)
                    {
                        sb.Append(", " + Lang.Get("{1:0.#} days left to ripen ({0}%)",
                            (int)Math.Round(transitionLevel * 100.0),
                            (state.TransitionHours - state.TransitionedHours) / api.World.Calendar.HoursPerDay / ripenRate));
                    }
                    else
                    {
                        double days = freshHoursLeft / api.World.Calendar.HoursPerDay;
                        if (days >= api.World.Calendar.DaysPerYear)
                            sb.Append(", " + Lang.Get("will ripen in {0} years", Math.Round(days / api.World.Calendar.DaysPerYear, 1)));
                        else if (days >= 1)
                            sb.Append(", " + Lang.Get("will ripen in {0} days", Math.Round(days, 1)));
                        else
                            sb.Append(", " + Lang.Get("will ripen in {0} hours", Math.Round(freshHoursLeft, 1)));
                    }
                }
                else if (props.Type == EnumTransitionType.Perish)
                {
                    hasPerish = true;
                    if (transitionLevel > 0f)
                    {
                        sb.Append(", " + Lang.Get("{0}% spoiled", (int)Math.Round(transitionLevel * 100.0)));
                    }
                    else
                    {
                        double days = freshHoursLeft / api.World.Calendar.HoursPerDay;
                        if (days >= api.World.Calendar.DaysPerYear)
                            sb.Append(", " + Lang.Get("fresh for {0} years", Math.Round(days / api.World.Calendar.DaysPerYear, 1)));
                        else if (days >= 1)
                            sb.Append(", " + Lang.Get("fresh for {0} days", Math.Round(days, 1)));
                        else
                            sb.Append(", " + Lang.Get("fresh for {0} hours", Math.Round(freshHoursLeft, 1)));
                    }
                }
            }

            sb.AppendLine();
            return sb.ToString();
        }

        // ── Public accessors ─────────────────────────────────────────────────
        public List<SlotGroupDef> GetSlotGroupsPublic() => GetSlotGroups();
        public int GetGroupFrameBoxCountPublic(int groupIndex) => BoxCache?.GetGroupFrameBoxes(groupIndex).Length ?? 0;
        public int GetGroupForSlotPublic(int slotIndex) => GetGroupForSlot(slotIndex);

        private List<SlotGroupDef> _slotGroups = null;

        private List<SlotGroupDef> GetSlotGroups()
        {
            if (_slotGroups != null) return _slotGroups;
            var groups = new List<SlotGroupDef>();
            JsonObject groupsAttr = Block?.Attributes?["slotGroups"];
            if (groupsAttr != null && groupsAttr.Exists)
            {
                var arr = groupsAttr.AsArray();
                if (arr != null)
                {
                    foreach (var g in arr)
                    {
                        groups.Add(new SlotGroupDef
                        {
                            Count = g["count"].AsInt(7),
                            Spacing = g["spacing"].AsFloat(0.125f),
                            StartOffset = g["startOffset"].AsFloat(-0.375f),
                            ZCenter = g["zCenter"].AsFloat(0.281f),
                            YOffset = g["yOffset"].AsFloat(0.00f),
                            RotateY = g["rotateY"].AsFloat(0f)
                        });
                    }
                }
            }
            if (groups.Count == 0)
            {
                groups.Add(new SlotGroupDef
                {
                    Count = slotCount,
                    Spacing = 0.125f,
                    StartOffset = -0.375f,
                    ZCenter = 0.281f,
                    YOffset = 0f,
                    RotateY = 0f
                });
            }
            _slotGroups = groups;
            return _slotGroups;
        }

        private StaggerMode GetGroupStaggerMode(int groupIndex)
        {
            if (staggerModes == null || groupIndex >= staggerModes.Length) return StaggerMode.Straight;
            return (StaggerMode)staggerModes[groupIndex];
        }

        protected override float[][] genTransformationMatrices()
        {
            float[][] matrices = new float[slotCount][];
            var config = WindowStorageLibConfig.Current;
            float staggerForward = config.StaggerForwardOffset;
            float voxel = 1f / 32f;

            List<SlotGroupDef> groups = GetSlotGroups();
            int slotIndex = 0;

            for (int g = 0; g < groups.Count; g++)
            {
                var group = groups[g];
                StaggerMode groupStagger = GetGroupStaggerMode(g);

                for (int i = 0; i < group.Count; i++)
                {
                    if (slotIndex >= slotCount) break;

                    float x = group.StartOffset + (group.Spacing * i);
                    float y = group.YOffset;
                    float z = group.ZCenter;

                    switch (groupStagger)
                    {
                        case StaggerMode.Alternating:
                            float snappedForward = (float)Math.Round(staggerForward / voxel) * voxel;
                            z = (i % 2 == 0) ? group.ZCenter : group.ZCenter + snappedForward;
                            break;
                        case StaggerMode.Random:
                            z = group.ZCenter + (float)Math.Round(depths[slotIndex] / voxel) * voxel;
                            break;
                        case StaggerMode.FineTune:
                            z = group.ZCenter + depths[slotIndex];
                            break;
                    }

                    matrices[slotIndex] = CreateMatrix(x, y, z, slotIndex, group.RotateY);
                    slotIndex++;
                }
            }

            return matrices;
        }

        private float[] CreateMatrix(float x, float y, float z, int i, float baseRotateY = 0f)
        {
            return new Matrixf()
                .Translate(0.5f, 0.0f, 0.5f)
                .RotateYDeg(MeshAngleRad * GameMath.RAD2DEG)
                .Translate(x, y, z)
                .RotateYDeg(rotations[i] + baseRotateY)
                .Translate(-0.5f, 0.0f, -0.5f)
                .Values;
        }

        internal MeshData blockMesh;

        private void UpdateBlockMesh()
        {
            if (capi == null) return;

            capi.Event.EnqueueMainThreadTask(() =>
            {
                if (_disposed) return;

                blockMeshRef?.Dispose();
                blockMeshRef = null;

                var arlBlockBehavior = Block?.GetBehavior<BlockBehaviorShapeTexturesFromAttributes>();
                var arlBeBehavior = this.GetBehavior<BlockEntityBehaviorShapeTexturesFromAttributes>();

                if (arlBlockBehavior != null && arlBeBehavior != null)
                {
                    CompositeShape cshape = Block.Attributes?["shape"].AsObject<CompositeShape>() ?? Block.Shape;
                    blockMesh = arlBlockBehavior.GetOrCreateMesh(
                        arlBeBehavior.Variants,
                        cshape,
                        Pos,
                        null,
                        null
                    )?.Clone();
                }
                else
                {
                    capi.Tesselator.TesselateBlock(Block, out blockMesh);
                }

                if (blockMesh != null && MeshAngleRad != 0f)
                    blockMesh = blockMesh.Rotate(new Vec3f(0.5f, 0.0f, 0.5f), 0f, MeshAngleRad, 0f);

                if (blockMesh != null)
                    blockMeshRef = capi.Render.UploadMesh(blockMesh);

            }, "windowstoragelib-uploadmesh");
        }

        public override bool OnTesselation(ITerrainMeshPool mesher, ITesselatorAPI tessThreadTesselator)
        {
            if (blockMesh == null)
                UpdateBlockMesh();

            if (blockMesh != null)
                mesher.AddMeshData(blockMesh);

            base.OnTesselation(mesher, tessThreadTesselator);
            return true;
        }

        private void OnEventBusEvent(string eventName, ref EnumHandling handling, IAttribute data)
        {
            if (eventName != "genjsontransform" && eventName != "oncloseedittransforms" && eventName != "onapplytransforms")
                return;
            if (capi == null || Inventory.Empty) return;
            MarkMeshesDirty();
        }

        private int GetGroupForSlot(int slotIndex)
        {
            var groups = GetSlotGroups();
            int offset = 0;
            for (int g = 0; g < groups.Count; g++)
            {
                if (slotIndex < offset + groups[g].Count) return g;
                offset += groups[g].Count;
            }
            return 0;
        }

        public bool TryPut(ItemSlot slot, BlockSelection blockSel)
        {
            if (blockSel == null) return false;
            int index = blockSel.SelectionBoxIndex;
            if (index < 0 || index >= slotCount) return false;
            if (IsGroupStacked(GetGroupForSlot(index))) return false;
            ItemSlot targetSlot = inv[index];
            if (!targetSlot.Empty) return false;
            int moved = slot.TryPutInto(Api.World, targetSlot);
            if (moved > 0)
            {
                MarkDirty(true);
                Api.World.PlaySoundAt(new AssetLocation("game", "sounds/player/build"), Pos.X + 0.5, Pos.Y + 0.5, Pos.Z + 0.5, null, randomizePitch: true, range: 16);
                return true;
            }
            return false;
        }

        public bool TryTake(IPlayer byPlayer, BlockSelection blockSel)
        {
            if (blockSel == null) return false;
            int index = blockSel.SelectionBoxIndex;
            if (index < 0 || index >= slotCount) return false;
            if (IsGroupStacked(GetGroupForSlot(index))) return false;
            ItemSlot sourceSlot = inv[index];
            if (sourceSlot.Empty) return false;
            ItemStack stack = sourceSlot.TakeOut(1);
            if (byPlayer.InventoryManager.TryGiveItemstack(stack))
            {
                MarkDirty(true);
                Api.World.PlaySoundAt(new AssetLocation("game", "sounds/player/build"), Pos.X + 0.5, Pos.Y + 0.5, Pos.Z + 0.5, null, randomizePitch: true, range: 16);
                return true;
            }
            sourceSlot.Itemstack = stack;
            return false;
        }
    }
